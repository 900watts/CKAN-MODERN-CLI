<?xml version="1.0" encoding="utf-8"?>
<log4net>
  <appender name="CliFile" type="log4net.Appender.RollingFileAppender">
    <file value="kerbclaw-cli.log" />
    <appendToFile value="true" />
    <rollingStyle value="Size" />
    <maxSizeRollBackups value="3" />
    <maximumFileSize value="1MB" />
    <staticLogFileName value="true" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{HH:mm:ss} %level %logger - %message%newline" />
    </layout>
  </appender>

  <!-- Suppress console output; route all log messages to file -->
  <root>
    <level value="INFO" />
    <appender-ref ref="CliFile" />
  </root>
</log4net>
